{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": [],
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["./core/*"],
      "@modules/*": ["./modules/*"],
      "@components/*": ["./components/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
